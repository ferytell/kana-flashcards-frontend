{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug React Brave",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "runtimeExecutable": "/usr/bin/brave-browser"
    },
    {
      "name": "Debug React (Edge)",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true
    }
  ]
}
